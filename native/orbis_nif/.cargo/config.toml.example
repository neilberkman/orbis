# Local-development override for the astrodynamics crates.
#
# orbis_nif/Cargo.toml pins astrodynamics + astrodynamics-gnss to the release
# versions. While developing the next release before those versions exist on
# crates.io, copy this file to `config.toml` in this directory and set the two
# paths to your checkout.
#
# `config.toml` is gitignored — never commit a path override, or CI/external
# builds break again.
#
#   cp config.toml.example config.toml
#   # then edit the paths below to your local astrodynamics workspace
#
[patch.crates-io]
astrodynamics = { path = "/absolute/path/to/astrodynamics/crates/astrodynamics" }
astrodynamics-gnss = { path = "/absolute/path/to/astrodynamics/crates/astrodynamics-gnss" }
